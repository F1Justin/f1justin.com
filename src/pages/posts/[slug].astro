---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// 日期格式化
function formatDate(date: Date): string {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}年${month}月${day}日`;
}
---

<Layout 
  title={`${post.data.title} | F1JUSTIN`} 
  description={post.data.summary || post.data.title}
>
  <article class="post-detail">
    <div class="container">
      <div class="post-header">
        <a href="/posts" class="back-link">← 返回文章列表</a>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </div>
      </div>
      
      <div class="post-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-detail {
    padding: var(--space-xl) 0;
  }

  .post-header {
    margin-bottom: var(--space-lg);
  }

  .back-link {
    display: inline-block;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-sm);
  }

  .post-meta {
    color: var(--color-text-secondary);
    font-size: 0.9em;
  }

  .post-content {
    max-width: 800px;
  }

  /* Markdown 样式 */
  .post-content :global(h2) {
    font-size: 1.5em;
    margin-top: 48px;
    margin-bottom: 16px;
    border-bottom: 2px solid color-mix(in srgb, var(--color-bg) 90%, var(--color-text) 10%);
    padding-bottom: 8px;
  }

  .post-content :global(h3) {
    font-size: 1.25em;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  .post-content :global(p) {
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-bottom-color 0.2s ease;
  }

  .post-content :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }

  .post-content :global(code) {
    background-color: color-mix(in srgb, var(--color-bg) 90%, var(--color-text) 10%);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Monaco', 'Consolas', monospace;
  }

  .post-content :global(pre) {
    background-color: color-mix(in srgb, var(--color-bg) 90%, var(--color-text) 10%);
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 24px 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 20px;
    margin: 24px 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-left: 24px;
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 24px 0;
  }

  @media (max-width: 768px) {
    .post-content {
      font-size: 0.95em;
    }
  }
</style>
