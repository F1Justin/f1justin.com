---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';

// 获取所有文章并按日期排序
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

// 日期格式化函数
function formatDate(date: Date): string {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}
---

<Layout title="文章 | F1JUSTIN" description="阅读我的思考与观察">
  <section class="posts-page">
    <div class="container">
      <h1>文章</h1>
      
      {sortedPosts.length > 0 ? (
        <div class="posts-list">
          {sortedPosts.map((post) => (
            <a href={`/posts/${post.id.replace(/\.md$/, '')}`} class="post-card">
              <h3 class="post-title">{post.data.title}</h3>
              <div class="post-date">{formatDate(post.data.date)}</div>
              {post.data.summary && (
                <p class="post-summary">{post.data.summary}</p>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">📝</div>
          <h2>暂无文章</h2>
          <p>敬请期待更多深度思考...</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .posts-page {
    padding: var(--space-xl) 0;
    min-height: 60vh;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .post-card {
    background-color: var(--color-bg);
    border: 3px solid var(--color-text);
    border-radius: 0px;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s ease, background-color 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-card:hover {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-bg) 98%, var(--color-accent) 2%);
  }

  .post-title {
    font-size: 1.25em;
    font-weight: 700;
    margin: 0;
  }

  .post-date {
    font-size: 0.8em;
    color: var(--color-text-secondary);
  }

  .post-summary {
    font-size: 0.95em;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: var(--space-md);
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .post-card {
      padding: var(--space-sm);
    }
  }
</style>
