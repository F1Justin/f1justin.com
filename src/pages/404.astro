---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - 页面不存在 | F1JUSTIN">
  <section class="error-page">
    <div class="container">
      <h1 class="error-code">404</h1>
      <h2 class="error-message">页面不存在</h2>
      <p class="error-hint">抱歉，您访问的页面不存在或已被移除。</p>
      
      <div class="error-actions">
        <a href="/" class="error-link">返回首页</a>
        <a href="/works" class="error-link">查看作品</a>
        <a href="/posts" class="error-link">阅读文章</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .error-code {
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 900;
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
    line-height: 1;
  }

  .error-message {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: var(--space-sm);
  }

  .error-hint {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    font-size: 1.1em;
  }

  .error-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .error-link {
    display: inline-block;
    padding: 12px 24px;
    background-color: color-mix(in srgb, var(--color-bg) 90%, var(--color-text) 10%);
    color: var(--color-text);
    text-decoration: none;
    border-radius: 6px;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .error-link:hover {
    transform: translateY(-2px);
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  @media (max-width: 768px) {
    .error-actions {
      flex-direction: column;
      gap: var(--space-sm);
    }
    
    .error-link {
      width: 100%;
      max-width: 300px;
    }
  }
</style>

