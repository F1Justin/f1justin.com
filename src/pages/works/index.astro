---
import Layout from "../../layouts/Layout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getCollection } from 'astro:content';

// 获取所有作品并按时间排序
const allWorks = await getCollection('works');

// 时间解析函数
function parseTimeRange(timeRange: string): Date {
  if (timeRange.includes('至今')) {
    return new Date(); // 当前时间（最新）
  }
  
  // 提取日期字符串（YYYY-MM 格式）
  const match = timeRange.match(/(\d{4}-\d{2})/g);
  if (match && match.length > 0) {
    // 如果有范围（如 "2024-03 - 2024-08"），取最后一个日期
    const dateStr = match[match.length - 1];
    return new Date(dateStr + '-01');
  }
  
  return new Date(0); // 默认返回最早日期
}

// 按时间倒序排序
const sortedWorks = allWorks.sort((a, b) => {
  const dateA = parseTimeRange(a.data.time_range);
  const dateB = parseTimeRange(b.data.time_range);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout title="作品 | F1JUSTIN" description="查看我的技术项目与创作作品">
  <section class="works-page">
    <div class="container">
      <h1>作品</h1>
      
      {sortedWorks.length > 0 ? (
        <div class="works-list">
          {sortedWorks.map((work) => (
            <WorkCard work={work.data} variant="list" />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">📦</div>
          <h2>暂无作品</h2>
          <p>作品正在创作中...</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .works-page {
    padding: var(--space-xl) 0;
    min-height: 60vh;
  }

  .works-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: var(--space-md);
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }
</style>

