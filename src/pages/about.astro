---
import Layout from "../layouts/Layout.astro";
import SocialIcons from "../components/SocialIcons";

const interests = [
  {
    id: "tech",
    category: "技术",
    items: [
      "Linux 桌面与服务器 (Arch、Fedora、Debian、macOS)",
      "Vim / Neovim & Git CLI 工作流",
      "Docker 与自托管服务部署",
      "服务器运维（Minecraft、Nonebot 等）",
      "Python（数据分析 & Bot 插件）",
      "Swift / SwiftUI（macOS 应用）",
      "SQL & PostgreSQL"
    ],
    icon: "💻"
  },
  {
    id: "visual",
    category: "摄影 & 多媒体",
    items: [
      "街头纪实 / 风景摄影",
      "使用相机&手机&无人机",
      "OBS 多媒体系统搭建",
      "HDR 内容创作",
      "并置美学探索"
    ],
    icon: "📷"
  },
  {
    id: "reading",
    category: "阅读 & 思考",
    items: [
      "思想史 / 社会学 / 哲学",
      "科幻文学（莱姆、PKD）",
      "亚文化研究与网络梗史",
      "城市文化与交通系统观察",
      "深度阅读实践"
    ],
    icon: "📚"
  },
  {
    id: "hardware",
    category: "DIY & 硬件",
    items: [
      "自组 NAS 与家庭服务器",
      "路由器 OpenWrt 刷机与调优",
      "焊接、热熔胶、木工",
      "便携手电 & 灯具改装"
    ],
    icon: "🔧"
  }
];
---

<Layout title="关于 | F1JUSTIN" description="了解我的背景、技能与兴趣">
  <section class="about-intro">
    <div class="container">
      <h1>关于我</h1>
      <div class="about-content">
        <div class="about-image">
          <img src="/images/avatar.jpg" alt="F1JUSTIN" />
        </div>
        <div class="about-text">
          <p>
            你好！我是 F1JUSTIN，一个充满好奇心的人，喜欢探索新技术和其他各类事物。
          </p>
          <p>
            "Wir müssen wissen. Wir werden wissen."（我们必须知道，我们终将知道）是德国数学家希尔伯特的名言，也是我的座右铭。
            我觉得这代表了一种精神——对知识的永恒追求。
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <section class="interests-section">
    <div class="container">
      <h2>兴趣与技能</h2>
      <div class="interests-container">
        {interests.map((category) => (
          <div id={category.id} class="interest-category">
            <h3><span class="category-icon">{category.icon}</span> {category.category}</h3>
            <ul>
              {category.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <section class="contact-section">
    <div class="container">
      <h2>联系我</h2>
      <p>如果你感兴趣，或者想要了解更多信息，可以通过以下方式联系我：</p>
      
      <div class="contact-email">
        <h3>Email</h3>
        <a href="mailto:f1justin@outlook.com">f1justin@outlook.com</a>
      </div>
      
      <div class="social-links-container">
        <h3>社交媒体</h3>
        <SocialIcons client:load />
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-intro {
    padding: var(--space-xl) 0;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-lg);
    margin: var(--space-lg) 0;
  }
  
  .about-image {
    overflow: hidden;
    border-radius: 50%;
    width: 250px;
    height: 250px;
    justify-self: center;
  }
  
  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .about-text p {
    line-height: 1.8;
  }

  .interests-section {
    padding: var(--space-xl) 0;
    background-color: color-mix(in srgb, var(--color-bg) 95%, var(--color-text) 5%);
  }
  
  .interests-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-lg);
    margin: var(--space-lg) 0;
  }
  
  .interest-category {
    background-color: var(--color-bg);
    border: 1px solid var(--color-text);
    padding: var(--space-md);
    border-radius: 8px;
    transition: border-color 0.3s ease, background-color 0.3s ease;
    scroll-margin-top: 100px;
  }
  
  .interest-category:hover {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-bg) 98%, var(--color-accent) 2%);
  }
  
  .category-icon {
    margin-right: var(--space-xs);
    font-size: 1.2em;
  }
  
  .interest-category h3 {
    margin-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: var(--space-xs);
    display: inline-block;
  }
  
  .interest-category ul {
    list-style: none;
    margin-left: var(--space-sm);
  }
  
  .interest-category li {
    margin-bottom: var(--space-xs);
    position: relative;
    padding-left: var(--space-sm);
    line-height: 1.8;
  }
  
  .interest-category li:before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .contact-section {
    padding: var(--space-xl) 0;
  }
  
  .contact-email {
    margin: var(--space-md) 0;
  }
  
  .contact-email a {
    color: var(--color-accent);
    text-decoration: underline;
    font-weight: 500;
  }
  
  .social-links-container {
    margin-top: var(--space-md);
  }

  :global(.social-links) {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }
  
  :global(.social-link) {
    display: flex;
    align-items: center;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s ease, border-color 0.3s ease;
    padding: 8px 16px;
    border-radius: 0px;
    border: 3px solid var(--color-text);
    background-color: var(--color-bg);
  }
  
  :global(.social-link:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  
  :global(.social-link svg) {
    margin-right: var(--space-xs);
  }

  @media (max-width: 768px) {
    .about-content {
      grid-template-columns: 1fr;
    }
    
    .about-image {
      margin: 0 auto;
    }
    
    .interests-container {
      grid-template-columns: 1fr;
    }
    
    :global(.social-links) {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>

