---
interface Props {
  theme: {
    emoji: string;
    title: string;
    keywords: string[];
    anchor: string;
  };
}

const { theme } = Astro.props;
---

<a href={`/about#${theme.anchor}`} class="theme-card">
  <div class="theme-icon">{theme.emoji}</div>
  <h3 class="theme-title">{theme.title}</h3>
  <p class="theme-keywords">
    {theme.keywords.join(' · ')}
  </p>
</a>

<style>
  .theme-card {
    background-color: var(--color-bg);
    border: 4px solid var(--color-text);
    border-radius: 0px;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .theme-card:hover {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-bg) 98%, var(--color-accent) 2%);
  }

  .theme-card:hover .theme-keywords {
    opacity: 1;
  }

  .theme-icon {
    font-size: 2em;
    margin-bottom: var(--space-xs);
  }

  .theme-title {
    font-size: 1.1em;
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .theme-keywords {
    font-size: 0.85em;
    color: var(--color-text-secondary);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .theme-card {
      padding: var(--space-sm);
    }
  }
</style>

