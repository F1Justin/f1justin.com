---
interface Props {
  work: {
    title: string;
    emoji: string;
    tagline: string;
    time_range: string;
    links?: {
      github?: string;
      post?: string;
    };
  };
  variant?: 'featured' | 'list';
}

const { work, variant = 'featured' } = Astro.props;
const isOngoing = work.time_range.includes('至今');
---

<div class={`work-card ${variant}`}>
  <div class="work-header">
    <span class="work-emoji">{work.emoji}</span>
    <span class="work-time">
      {isOngoing && <span class="status-indicator"></span>}
      {work.time_range}
    </span>
  </div>
  
  <h3 class="work-title">{work.title}</h3>
  <p class="work-tagline">{work.tagline}</p>
  
  {work.links && (work.links.github || work.links.post) && (
    <div class="work-links">
      {work.links.github && (
        <a href={work.links.github} target="_blank" rel="noopener noreferrer" class="work-link">
          GitHub →
        </a>
      )}
      {work.links.post && (
        <a href={`/posts/${work.links.post}`} class="work-link">
          详细介绍 →
        </a>
      )}
    </div>
  )}
</div>

<style>
  .work-card {
    background-color: var(--color-bg);
    border: 3px solid var(--color-text);
    border-radius: 0px;
    padding: var(--space-md);
    transition: border-color 0.3s ease, background-color 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work-card:hover {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-bg) 94%, var(--color-accent) 6%);
  }

  .work-card.list {
    padding: var(--space-sm) var(--space-md);
  }

  .work-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .work-emoji {
    font-size: 2em;
    line-height: 1;
  }

  .work-card.list .work-emoji {
    font-size: 1.5em;
  }

  .work-time {
    font-size: 0.8em;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-indicator {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #10b981;
  }

  .work-title {
    font-size: 1.25em;
    font-weight: 700;
    margin: var(--space-xs) 0;
  }

  .work-card.list .work-title {
    font-size: 1.1em;
  }

  .work-tagline {
    font-size: 0.9em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .work-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-xs);
  }

  .work-link {
    font-size: 0.9em;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .work-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .work-card {
      padding: var(--space-sm);
    }
  }
</style>

